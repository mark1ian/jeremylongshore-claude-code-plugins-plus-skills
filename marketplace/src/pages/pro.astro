---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = "Tons of Skills Pro — Priority Support & Hosted Analytics";
const description = "Priority support, hosted analytics, and enterprise features for production Claude Code teams. $29/month per seat. 14-day free trial.";
---

<BaseLayout title={title} description={description}>
  <style>
    /* ── Page shell ── */
    .pro-page {
      --pro-accent: var(--primary);
      --pro-accent-tint: var(--primary-tint);
      --pro-accent-border: var(--primary-border);
    }

    /* ── Hero ── */
    .pro-hero {
      text-align: center;
      padding: var(--space-12) var(--space-6) var(--space-10);
      background: linear-gradient(
        180deg,
        oklch(62% 0.16 35 / 0.06) 0%,
        transparent 100%
      );
      border-bottom: 1px solid var(--border);
    }

    .pro-eyebrow {
      display: inline-block;
      font-family: 'DM Mono', monospace;
      font-size: var(--text-xs);
      font-weight: 500;
      color: var(--primary);
      text-transform: uppercase;
      letter-spacing: 0.12em;
      background: var(--primary-tint);
      border: 1px solid var(--primary-border);
      border-radius: var(--radius-sm);
      padding: 0.3rem 0.75rem;
      margin-bottom: var(--space-5);
    }

    .pro-hero h1 {
      font-size: var(--text-3xl);
      font-family: 'Instrument Sans', system-ui, sans-serif;
      font-weight: 700;
      letter-spacing: -0.03em;
      color: var(--text);
      margin-bottom: var(--space-4);
      line-height: 1.1;
    }

    .pro-hero h1 span {
      color: var(--primary);
    }

    .pro-subtitle {
      font-size: var(--text-lg);
      color: var(--text-2);
      max-width: 44rem;
      margin: 0 auto var(--space-6);
      line-height: 1.6;
    }

    .pro-price-callout {
      display: inline-flex;
      align-items: baseline;
      gap: var(--space-2);
      background: var(--card);
      border: 1px solid var(--primary-border);
      border-radius: var(--radius-lg);
      padding: var(--space-4) var(--space-6);
      margin-bottom: var(--space-6);
    }

    .pro-price-amount {
      font-family: 'Instrument Sans', system-ui, sans-serif;
      font-size: clamp(2.5rem, 5vw, 3.5rem);
      font-weight: 700;
      color: var(--primary);
      letter-spacing: -0.03em;
      line-height: 1;
    }

    .pro-price-meta {
      font-family: 'Source Sans 3', system-ui, sans-serif;
      font-size: var(--text-base);
      color: var(--text-2);
    }

    .hero-cta-group {
      display: flex;
      gap: var(--space-3);
      justify-content: center;
      flex-wrap: wrap;
    }

    .btn-primary {
      display: inline-block;
      padding: 0.875rem 2rem;
      font-family: 'Instrument Sans', system-ui, sans-serif;
      font-size: var(--text-base);
      font-weight: 600;
      color: oklch(99% 0.002 60);
      background: var(--primary);
      border-radius: var(--radius-md);
      text-decoration: none;
      transition: var(--card-transition);
      border: 1px solid transparent;
    }

    .btn-primary:hover {
      background: var(--primary-dark);
      transform: translateY(-1px);
      box-shadow: 0 6px 20px oklch(62% 0.16 35 / 0.3);
    }

    .btn-secondary {
      display: inline-block;
      padding: 0.875rem 2rem;
      font-family: 'Instrument Sans', system-ui, sans-serif;
      font-size: var(--text-base);
      font-weight: 600;
      color: var(--text-2);
      background: transparent;
      border: 1px solid var(--border-bright);
      border-radius: var(--radius-md);
      text-decoration: none;
      transition: var(--card-transition);
    }

    .btn-secondary:hover {
      color: var(--text);
      border-color: var(--primary);
      background: var(--primary-tint);
    }

    .hero-note {
      margin-top: var(--space-4);
      font-family: 'DM Mono', monospace;
      font-size: var(--text-xs);
      color: var(--text-3);
    }

    /* ── Section scaffolding ── */
    .pro-section {
      padding: var(--space-10) var(--space-6);
    }

    .pro-section-alt {
      background: var(--surface);
      border-top: 1px solid var(--border);
      border-bottom: 1px solid var(--border);
    }

    .section-inner {
      max-width: 72rem;
      margin: 0 auto;
    }

    .section-header {
      text-align: center;
      margin-bottom: var(--space-8);
    }

    .section-label {
      display: inline-block;
      font-family: 'DM Mono', monospace;
      font-size: var(--text-xs);
      font-weight: 500;
      color: var(--text-3);
      text-transform: uppercase;
      letter-spacing: 0.1em;
      margin-bottom: var(--space-3);
    }

    .section-title {
      font-family: 'Instrument Sans', system-ui, sans-serif;
      font-size: var(--text-2xl);
      font-weight: 700;
      letter-spacing: -0.025em;
      color: var(--text);
      margin-bottom: var(--space-3);
    }

    .section-desc {
      font-size: var(--text-base);
      color: var(--text-2);
      max-width: 44rem;
      margin: 0 auto;
      line-height: 1.7;
    }

    /* ── Feature columns ── */
    .feature-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(19rem, 1fr));
      gap: var(--space-5);
    }

    .feature-card {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: var(--card-featured-radius);
      padding: var(--card-featured-padding);
      transition: var(--card-transition);
    }

    .feature-card:hover {
      border-color: var(--primary-border);
      transform: var(--card-hover-lift);
      box-shadow: var(--card-hover-shadow-accent);
    }

    .feature-icon {
      width: 44px;
      height: 44px;
      border-radius: var(--radius-md);
      background: var(--primary-tint);
      border: 1px solid var(--primary-border);
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: var(--space-4);
      color: var(--primary);
    }

    .feature-card h3 {
      font-family: 'Instrument Sans', system-ui, sans-serif;
      font-size: 1.05rem;
      font-weight: 600;
      color: var(--text);
      margin-bottom: var(--space-4);
    }

    .feature-list {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      flex-direction: column;
      gap: var(--space-3);
    }

    .feature-list li {
      display: flex;
      align-items: flex-start;
      gap: var(--space-3);
      font-size: var(--text-sm);
      color: var(--text-2);
      line-height: 1.5;
    }

    .check-mark {
      flex-shrink: 0;
      width: 16px;
      height: 16px;
      color: var(--positive);
      margin-top: 2px;
    }

    /* ── Free tier section ── */
    .free-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(14rem, 1fr));
      gap: var(--space-4);
    }

    .free-item {
      display: flex;
      align-items: flex-start;
      gap: var(--space-3);
      padding: var(--space-4);
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: var(--radius-lg);
    }

    .free-item-icon {
      flex-shrink: 0;
      width: 36px;
      height: 36px;
      border-radius: var(--radius-sm);
      background: oklch(65% 0.18 145 / 0.1);
      border: 1px solid oklch(65% 0.18 145 / 0.25);
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--positive);
    }

    .free-item-text strong {
      display: block;
      font-size: var(--text-sm);
      font-weight: 600;
      color: var(--text);
      margin-bottom: 0.2rem;
    }

    .free-item-text span {
      font-size: var(--text-xs);
      color: var(--text-3);
    }

    /* ── FAQ ── */
    .faq-list {
      max-width: 52rem;
      margin: 0 auto;
      display: flex;
      flex-direction: column;
      gap: var(--space-4);
    }

    .faq-item {
      background: var(--card);
      border: 1px solid var(--border);
      border-radius: var(--radius-lg);
      padding: var(--space-6);
      transition: border-color var(--duration-fast) var(--ease-out);
    }

    .faq-item:hover {
      border-color: var(--border-bright);
    }

    .faq-q {
      font-family: 'Instrument Sans', system-ui, sans-serif;
      font-size: var(--text-base);
      font-weight: 600;
      color: var(--text);
      margin-bottom: var(--space-3);
    }

    .faq-a {
      font-size: var(--text-sm);
      color: var(--text-2);
      line-height: 1.7;
    }

    /* ── Final CTA banner ── */
    .pro-cta-banner {
      padding: var(--space-10) var(--space-6);
      text-align: center;
      background: linear-gradient(
        135deg,
        oklch(62% 0.16 35 / 0.12) 0%,
        oklch(62% 0.16 35 / 0.04) 100%
      );
      border-top: 1px solid var(--primary-border);
    }

    .pro-cta-banner h2 {
      font-family: 'Instrument Sans', system-ui, sans-serif;
      font-size: var(--text-2xl);
      font-weight: 700;
      letter-spacing: -0.025em;
      color: var(--text);
      margin-bottom: var(--space-3);
    }

    .pro-cta-banner p {
      font-size: var(--text-base);
      color: var(--text-2);
      margin-bottom: var(--space-6);
      max-width: 36rem;
      margin-left: auto;
      margin-right: auto;
    }

    /* ── Responsive ── */
    @media (max-width: 768px) {
      .pro-hero {
        padding: var(--space-10) var(--space-5) var(--space-8);
      }

      .pro-section {
        padding: var(--space-8) var(--space-5);
      }

      .feature-grid {
        grid-template-columns: 1fr;
      }

      .free-grid {
        grid-template-columns: 1fr 1fr;
      }
    }

    @media (max-width: 480px) {
      .pro-price-callout {
        flex-direction: column;
        align-items: center;
        gap: 0.25rem;
      }

      .free-grid {
        grid-template-columns: 1fr;
      }
    }
  </style>

  <!-- Hero -->
  <section class="pro-hero">
    <div class="pro-eyebrow">Pro Tier</div>
    <h1>Tons of Skills <span>Pro</span></h1>
    <p class="pro-subtitle">
      Priority support and hosted analytics for production Claude Code teams.
      Everything stays free — Pro adds the layer your team actually needs.
    </p>

    <div class="pro-price-callout" role="presentation">
      <span class="pro-price-amount">$29</span>
      <span class="pro-price-meta">/ month per seat</span>
    </div>

    <div class="hero-cta-group">
      <a
        href="mailto:jeremy@intentsolutions.io?subject=Tons%20of%20Skills%20Pro%20Trial"
        class="btn-primary"
        aria-label="Start your 14-day free trial"
      >
        Start 14-Day Free Trial
      </a>
      <a href="#faq" class="btn-secondary">See FAQ</a>
    </div>

    <p class="hero-note">No credit card required &mdash; 14-day trial included</p>
  </section>

  <!-- What's Included -->
  <section class="pro-section">
    <div class="section-inner">
      <div class="section-header">
        <span class="section-label">What you get</span>
        <h2 class="section-title">Everything in Pro</h2>
        <p class="section-desc">
          Three pillars built for teams running Claude Code at scale.
        </p>
      </div>

      <div class="feature-grid">
        <!-- Priority Support -->
        <div class="feature-card">
          <div class="feature-icon" aria-hidden="true">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
            </svg>
          </div>
          <h3>Priority Support</h3>
          <ul class="feature-list" role="list">
            <li>
              <svg class="check-mark" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="2 8 6 12 14 4"/></svg>
              Direct Slack channel access
            </li>
            <li>
              <svg class="check-mark" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="2 8 6 12 14 4"/></svg>
              4-hour response SLA (business hours)
            </li>
            <li>
              <svg class="check-mark" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="2 8 6 12 14 4"/></svg>
              Monthly architecture review sessions
            </li>
            <li>
              <svg class="check-mark" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="2 8 6 12 14 4"/></svg>
              Priority bug fixes and escalations
            </li>
          </ul>
        </div>

        <!-- Hosted Analytics -->
        <div class="feature-card">
          <div class="feature-icon" aria-hidden="true">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/>
            </svg>
          </div>
          <h3>Hosted Analytics</h3>
          <ul class="feature-list" role="list">
            <li>
              <svg class="check-mark" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="2 8 6 12 14 4"/></svg>
              Cloud-hosted analytics dashboard
            </li>
            <li>
              <svg class="check-mark" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="2 8 6 12 14 4"/></svg>
              Team usage metrics and trends
            </li>
            <li>
              <svg class="check-mark" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="2 8 6 12 14 4"/></svg>
              Cost tracking per model and provider
            </li>
            <li>
              <svg class="check-mark" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="2 8 6 12 14 4"/></svg>
              90-day data retention
            </li>
          </ul>
        </div>

        <!-- Enterprise Features -->
        <div class="feature-card">
          <div class="feature-icon" aria-hidden="true">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>
            </svg>
          </div>
          <h3>Enterprise Features</h3>
          <ul class="feature-list" role="list">
            <li>
              <svg class="check-mark" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="2 8 6 12 14 4"/></svg>
              SSO / SAML integration support
            </li>
            <li>
              <svg class="check-mark" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="2 8 6 12 14 4"/></svg>
              Audit logging
            </li>
            <li>
              <svg class="check-mark" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="2 8 6 12 14 4"/></svg>
              Custom skill development
            </li>
            <li>
              <svg class="check-mark" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="2 8 6 12 14 4"/></svg>
              Dedicated onboarding session
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- What Stays Free -->
  <section class="pro-section pro-section-alt">
    <div class="section-inner">
      <div class="section-header">
        <span class="section-label">Free forever</span>
        <h2 class="section-title">What Always Stays Free</h2>
        <p class="section-desc">
          Pro is additive. The core marketplace is open source and will never be gated.
        </p>
      </div>

      <div class="free-grid">
        <div class="free-item">
          <div class="free-item-icon" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/>
            </svg>
          </div>
          <div class="free-item-text">
            <strong>414+ Plugins</strong>
            <span>Always free, always open source</span>
          </div>
        </div>

        <div class="free-item">
          <div class="free-item-icon" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>
            </svg>
          </div>
          <div class="free-item-text">
            <strong>CLI Tool (ccpi)</strong>
            <span>Install and manage plugins locally</span>
          </div>
        </div>

        <div class="free-item">
          <div class="free-item-icon" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
            </svg>
          </div>
          <div class="free-item-text">
            <strong>Community Support</strong>
            <span>GitHub Issues, open to everyone</span>
          </div>
        </div>

        <div class="free-item">
          <div class="free-item-icon" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/>
            </svg>
          </div>
          <div class="free-item-text">
            <strong>Standard Documentation</strong>
            <span>Full docs and playbooks</span>
          </div>
        </div>

        <div class="free-item">
          <div class="free-item-icon" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
            </svg>
          </div>
          <div class="free-item-text">
            <strong>Marketplace Access</strong>
            <span>Search, browse, and explore</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="pro-section" id="faq">
    <div class="section-inner">
      <div class="section-header">
        <span class="section-label">Common questions</span>
        <h2 class="section-title">FAQ</h2>
      </div>

      <div class="faq-list" role="list">
        <div class="faq-item" role="listitem">
          <p class="faq-q">Do I need Pro to use plugins?</p>
          <p class="faq-a">
            No. All 414+ plugins are free forever and always will be. Pro adds support
            SLA, hosted analytics, and enterprise features on top of the free tier.
          </p>
        </div>

        <div class="faq-item" role="listitem">
          <p class="faq-q">What's the difference between Free and Pro?</p>
          <p class="faq-a">
            Free gives you the full marketplace, CLI tool, and community support via GitHub.
            Pro adds a direct Slack line with a 4-hour response SLA, a cloud-hosted analytics
            dashboard with 90-day retention, and enterprise features like SSO and audit logging.
          </p>
        </div>

        <div class="faq-item" role="listitem">
          <p class="faq-q">Can I try before I buy?</p>
          <p class="faq-a">
            Yes. Every Pro plan starts with a 14-day free trial. No credit card required
            to get started — just email to kick off the trial.
          </p>
        </div>

        <div class="faq-item" role="listitem">
          <p class="faq-q">Is there an Enterprise plan?</p>
          <p class="faq-a">
            Yes. For larger teams with custom requirements — dedicated infrastructure,
            SLAs beyond the standard tier, or bespoke skill development at volume —
            contact us for custom pricing.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="pro-cta-banner">
    <h2>Ready to get started?</h2>
    <p>
      14-day free trial, no credit card required. Cancel any time.
    </p>
    <div class="hero-cta-group">
      <a
        href="mailto:jeremy@intentsolutions.io?subject=Tons%20of%20Skills%20Pro%20Trial"
        class="btn-primary"
        aria-label="Start your 14-day free trial"
      >
        Start 14-Day Free Trial
      </a>
      <a
        href="mailto:jeremy@intentsolutions.io?subject=Tons%20of%20Skills%20Enterprise%20Inquiry"
        class="btn-secondary"
      >
        Contact for Enterprise
      </a>
    </div>
  </section>
</BaseLayout>
